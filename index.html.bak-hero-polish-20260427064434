      'GTA United': 'GTA United',
      'St Kitts': 'Hrvat St. Catharines',
      'Celtic': 'Toronto Celtic',
      'Guelph': 'Guelph Royals',
      'Vaughan': 'Vaughan Azzurri',
      'Vaughan Azzurri': 'Vaughan Azzurri',
      'Hrvat St. Catharines': 'Hrvat St. Catharines',
      'Croatia Norval': 'Croatia Norval',
      'Toronto Celtic': 'Toronto Celtic',
      'Peniche CC': 'Peniche CC',
      'Guelph Royals': 'Guelph Royals',
      'Scarboro Azzurri Blues': 'Scarboro Azzurri Blues'
    };
    return aliases[name] || name;
  }

  function teamLogoHTML(name, size = 'xs') {
    const canonical = canonicalTeamName(name);
    const logo = teamLogos[canonical];
    if (!logo) {
      const initials = canonical.split(/\s+/).filter(Boolean).slice(0, 2).map(w => w[0]).join('').toUpperCase();
      return `<span class="team-logo-plate team-logo-plate--${size}"><span class="team-logo-initials">${initials}</span></span>`;
    }
    return `<span class="team-logo-plate team-logo-plate--${size}"><img src="${logo}" alt="${canonical} logo" loading="lazy"></span>`;
  }

  function teamNameHTML(name, size = 'xs') {
    const canonical = canonicalTeamName(name);
    return `<span class="team-lockup">${teamLogoHTML(name, size)}<span class="team-name">${canonical}</span></span>`;
  }


  function compBadgeHTML(comp, size = 'mini') {
    const cls = size === 'mini' ? 'comp-mini' : 'comp-badge';
    const logos = {
      'Cup': { cls: 'cup', src: 'data:image/png;base64,', alt: 'League Cup logo', fallback: 'CUP' },
      'OSL': { cls: 'osl', src: 'data:image/png;base64,', alt: 'OSL League logo', fallback: 'OSL' },
      'OntCup': { cls: 'ont', src: 'data:image/png;base64,', alt: 'Ontario Cup logo', fallback: 'ONT' },
      'Nat': { cls: 'nat', src: '', alt: 'National Championship', fallback: 'CAN' }
    };
    const item = logos[comp] || logos.OSL;
    if (item.src) return `<span class="${cls} comp-badge--${item.cls}"><img src="${item.src}" alt="${item.alt}" loading="lazy"></span>`;
    return `<span class="${cls} comp-badge--${item.cls}">${item.fallback}</span>`;
  }


  // ============================================================
  // RENDER
  // ============================================================
  const TODAY = new Date('2026-04-25T12:00:00-04:00');

  function ageOn(dobStr, refDate) {
    const dob = new Date(dobStr + 'T00:00:00');
    let age = refDate.getFullYear() - dob.getFullYear();
    const m = refDate.getMonth() - dob.getMonth();
    if (m < 0 || (m === 0 && refDate.getDate() < dob.getDate())) age--;
    return age;
  }
  function fmtDate(d) {
    return d.toLocaleDateString('en-CA', { weekday: 'short', month: 'short', day: 'numeric' });
  }
  function dayName(d) { return d.toLocaleDateString('en-CA', { weekday: 'short' }).toUpperCase(); }
  function monName(d) { return d.toLocaleDateString('en-CA', { month: 'short' }).toUpperCase(); }

  // Top date in header
  document.getElementById('topDate').textContent =
    TODAY.toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase();

  // Current Vaughan weather in header (Open-Meteo, no API key)
  const WEATHER_CODES = {
    0: ['☀️', 'Sunny'], 1: ['🌤️', 'Mainly clear'], 2: ['⛅', 'Partly cloudy'], 3: ['☁️', 'Cloudy'],
    45: ['🌫️', 'Fog'], 48: ['🌫️', 'Fog'], 51: ['🌦️', 'Light drizzle'], 53: ['🌦️', 'Drizzle'], 55: ['🌧️', 'Heavy drizzle'],
    61: ['🌧️', 'Light rain'], 63: ['🌧️', 'Rain'], 65: ['🌧️', 'Heavy rain'], 66: ['🌧️', 'Freezing rain'], 67: ['🌧️', 'Freezing rain'],
    71: ['🌨️', 'Light snow'], 73: ['🌨️', 'Snow'], 75: ['❄️', 'Heavy snow'], 77: ['🌨️', 'Snow grains'],
    80: ['🌦️', 'Rain showers'], 81: ['🌧️', 'Rain showers'], 82: ['⛈️', 'Heavy showers'],
    85: ['🌨️', 'Snow showers'], 86: ['❄️', 'Heavy snow showers'], 95: ['⛈️', 'Thunderstorm'], 96: ['⛈️', 'Thunderstorm'], 99: ['⛈️', 'Thunderstorm']
  };

  async function renderWeather() {
    const el = document.getElementById('topWeather');
    if (!el) return;
    try {
      const res = await fetch('https://api.open-meteo.com/v1/forecast?latitude=43.8372&longitude=-79.5083&current_weather=true&temperature_unit=celsius&timezone=America%2FToronto', { cache: 'no-store' });
      if (!res.ok) throw new Error('Weather unavailable');
      const data = await res.json();
      const current = data.current_weather;
      if (!current) throw new Error('No current weather');
      const [icon, label] = WEATHER_CODES[current.weathercode] || ['🌡️', 'Weather'];
      el.title = `Vaughan, Ontario · ${label}`;
      el.innerHTML = `<span class="weather-icon">${icon}</span><span class="weather-label">Vaughan</span><span class="weather-temp">${Math.round(current.temperature)}°C</span>`;
    } catch (err) {
      el.title = 'Vaughan weather unavailable';
      el.innerHTML = '<span class="weather-icon">⛅</span><span class="weather-label">Vaughan</span><span class="weather-temp">--°C</span>';
    }
  }
  renderWeather();

  // Find next fixture
  function fixtureDateTime(f) {
    const kickoff = /^\d{2}:\d{2}$/.test(f.t) ? f.t : '12:00';
    return new Date(`${f.d}T${kickoff}:00-04:00`);
  }

  const upcoming = fixtures
    .map(f => ({ ...f, when: fixtureDateTime(f) }))
    .filter(f => f.when >= TODAY)
    .sort((a, b) => a.when - b.when);

  const next = upcoming[0];
  if (next) {
    const days = Math.ceil((next.when - TODAY) / (1000 * 60 * 60 * 24));
    document.getElementById('daysToFirst').textContent = days;
    document.getElementById('nmDays').textContent = days;
    document.getElementById('nmOpp').innerHTML = `${teamLogoHTML(next.opp, 'lg')}${canonicalTeamName(next.opp)}`;
    const ph = document.getElementById('previewHomeLogo'); if (ph) ph.innerHTML = teamLogoHTML('Vaughan', 'md');
    const po = document.getElementById('previewOppLogo'); if (po) po.innerHTML = teamLogoHTML(next.opp, 'md');
    document.getElementById('nmDate').textContent = next.when.toLocaleDateString('en-CA', { weekday: 'long', month: 'short', day: 'numeric' });
    document.getElementById('nmTime').textContent = next.t === 'TBD' ? 'TBD' : next.t + ' ET';
    document.getElementById('nmVenue').textContent = next.venue;
    document.getElementById('nmHomeTag').textContent = next.home ? 'Home' : 'Away';
    document.getElementById('nmAwayTag').textContent = next.home ? 'Away' : 'Home';
    // Set comp pill
    const compPill = document.getElementById('nmCompPill');
    const compMap = { 'Cup': ['League Cup', 'fix-comp-cup'], 'OntCup': ['Ontario Cup', 'fix-comp-ont'], 'Nat': ['Nationals', 'fix-comp-nat'], 'OSL': ['OSL League', 'fix-comp-osl'] };
    const [label, cls] = compMap[next.comp] || compMap['OSL'];
    compPill.innerHTML = compBadgeHTML(next.comp, 'mini') + label;
    compPill.className = 'fix-comp-pill ' + cls;
    if (next.home) {
      // Vaughan listed first as home
    } else {
      // Show opponent first, us second
      const oppEl = document.getElementById('nmOpp');
      oppEl.classList.remove('us'); // already not us
    }
  }

  // Fixtures list (next 5 by default; toggle to show all)
  const fixtureList = document.getElementById('fixtureList');
  let showingAll = false;

  function renderFixtures() {
    fixtureList.innerHTML = '';
    const list = showingAll ? upcoming : upcoming.slice(0, 5);
    list.forEach(f => {
      const div = document.createElement('div');
      div.className = 'fixture';
      const compLabel = f.comp === 'Cup' ? 'League Cup' : (f.comp === 'OntCup' ? 'Ontario Cup' : (f.comp === 'Nat' ? 'Nationals' : 'OSL League'));
      const compClass = f.comp === 'Cup' ? 'fix-comp-cup' : (f.comp === 'OntCup' ? 'fix-comp-ont' : (f.comp === 'Nat' ? 'fix-comp-nat' : 'fix-comp-osl'));
      div.innerHTML = `
        <div class="fix-date">
          <div class="fix-day">${dayName(f.when)}</div>
          <div class="fix-num">${f.when.getDate()}</div>
          <div class="fix-mon">${monName(f.when)}</div>
        </div>
        <div class="fix-info">
          <div class="fix-opp-row">
            <span class="fix-comp-pill ${compClass}">${compBadgeHTML(f.comp, 'mini')}${compLabel}</span>
            <span class="fix-opp">${f.home ? 'vs' : '@'} ${teamNameHTML(f.opp, 'xs')}</span>
          </div>
          <div class="fix-loc">${f.venue}</div>
        </div>
        <div class="fix-time">
          <div class="fix-time-num">${f.t}</div>
          <div class="fix-time-tag ${f.home ? 'fix-tag-home' : 'fix-tag-away'}">${f.home ? 'Home' : 'Away'}</div>
        </div>
      `;
      fixtureList.appendChild(div);
    });
  }
  renderFixtures();

  document.getElementById('showMoreBtn').addEventListener('click', (e) => {
    showingAll = !showingAll;
    e.target.textContent = showingAll ? 'Show next 5 only' : 'Show all 19 fixtures';
    renderFixtures();
  });

  // Standings
  const standingsBody = document.getElementById('standingsBody');
  standings.forEach((s, i) => {
    const tr = document.createElement('tr');
    if (s.us) tr.className = 'us';
    tr.innerHTML = `
      <td class="num">${i + 1}</td>
      <td class="standings-team">${teamNameHTML(s.team, 'md')}</td>
      <td class="c num">0</td>
      <td class="c num">0</td>
      <td class="c num">0</td>
      <td class="c num">0</td>
      <td class="c num">0</td>
      <td class="c num">0</td>
      <td class="c num">0</td>
      <td class="r num"><b>0</b></td>
      <td>
        <span class="form">
          <span class="pip pip-empty"></span>
          <span class="pip pip-empty"></span>
          <span class="pip pip-empty"></span>
          <span class="pip pip-empty"></span>
          <span class="pip pip-empty"></span>
        </span>
      </td>
    `;
    standingsBody.appendChild(tr);
  });

  // Squad
  const squadGrid = document.getElementById('squadGrid');
  document.getElementById('squadCount').textContent = roster.length;
  // Sort: GK first, then by squad number
  const sorted = [...roster].sort((a, b) => {
    if (a.pos !== b.pos) {
      if (a.pos === 'GK') return -1;
      if (b.pos === 'GK') return 1;
    }
    return (a.num || 999) - (b.num || 999);
  });
  sorted.forEach(p => {
    const card = document.createElement('div');
    card.className = 'player-card';
    const ageStr = p.dob ? `${ageOn(p.dob, TODAY)} yrs` : '&mdash;';
    const fullName = [p.first, p.last].filter(Boolean).join(' ') || p.nick;
    const isGK = p.pos === 'GK';
    const posClass = isGK ? 'gk' : 'outfield';

    // Role badges
    const roles = [];
    if (p.captain) roles.push('<span class="pc-role-badge pc-role-capt">© Captain</span>');
    if (p.vc)      roles.push('<span class="pc-role-badge pc-role-vc">Vice Capt</span>');
    if (p.vc2)     roles.push('<span class="pc-role-badge pc-role-vc">2nd VC</span>');
    if (p.role === 'Sporting Director') roles.push('<span class="pc-role-badge pc-role-sd">Sporting Dir</span>');
    if (p.startingGK) roles.push('<span class="pc-role-badge pc-role-gk1">★ Starting GK</span>');
    if (p.backupGK)   roles.push('<span class="pc-role-badge pc-role-gk2">Backup GK</span>');
    const rolesHTML = roles.length ? `<div class="pc-roles">${roles.join('')}</div>` : '';

    const osaStr = p.osa ? ` · #${p.osa}` : ' · TBD';

    card.innerHTML = `
      <div class="player-card-top">
        <div style="min-width:0; flex:1;">
          <div class="pc-nick-wrap"><span class="position-icon ${isGK ? 'gk' : ''}">${isGK ? 'GK' : 'XI'}</span><div class="pc-nick">${p.nick}<span class="pc-flag" title="${p.natName}">${p.nat}</span></div></div>
          <div class="pc-fullname">${fullName}</div>
          ${rolesHTML}
        </div>
        <div class="pc-pos-box">
          <div class="pc-num">${p.num}</div>
          <div class="pc-pos ${posClass}">${p.pos}</div>
        </div>
      </div>
      <div class="pc-meta">${p.natName} · ${ageStr}${osaStr}</div>
      <div class="pc-stats">
        <div class="pc-stat"><div class="pc-stat-num">0</div><div class="pc-stat-lab">App</div></div>
        <div class="pc-stat"><div class="pc-stat-num">0</div><div class="pc-stat-lab">Gls</div></div>
        <div class="pc-stat"><div class="pc-stat-num">0</div><div class="pc-stat-lab">Ast</div></div>
        <div class="pc-stat"><div class="pc-stat-num">0</div><div class="pc-stat-lab">${isGK ? 'CS' : 'YC'}</div></div>
      </div>
    `;
    squadGrid.appendChild(card);
  });

  // ============================================================
  // Subscribe button device priority (for the calendar buttons)
  // ============================================================
  (function () {
    const ua = navigator.userAgent || '';
    const platform = navigator.platform || '';
    const isIOS = /iPad|iPhone|iPod/.test(ua) ||
                  (platform === 'MacIntel' && navigator.maxTouchPoints > 1);
    const isMac = /Mac/i.test(platform) && !isIOS;
    const isAndroid = /Android/i.test(ua);
    if (isAndroid) {
      // Swap order so Google appears first on Android
      const apple = document.getElementById('subApple');
      apple.parentNode.appendChild(apple);
    }
  })();
</script>

</body>
</html>
