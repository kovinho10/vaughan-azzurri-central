<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>Vaughan Azzurri Central &mdash; 2026 Season</title>
<meta name="description" content="Vaughan Azzurri season dashboard &mdash; calendar, standings, top scorers, clean sheets, attendance, and squad." />
<meta name="theme-color" content="#0a1428" />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800;900&family=Fraunces:ital,opsz,wght@0,9..144,400..900;1,9..144,400..900&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  :root {
    --bg: #0d1322;
    --bg-deep: #07101e;
    --surface: #161e35;
    --surface-raised: #1d2845;
    --surface-hi: #2a3760;
    --border: #2c3552;
    --border-hi: #3a4670;
    --azz: #3b82f6;
    --azz-bright: #60a5fa;
    --azz-deep: #1e40af;
    --paper: #f5f1e8;
    --text: #e8eef9;
    --muted: #8a9bbd;
    --dim: #5d6d8e;
    --win: #22c55e;
    --draw: #eab308;
    --loss: #ef4444;
    --rosso: #c8102e;
    --rosso-glow: rgba(220, 38, 56, 0.22);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Manrope', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body {
    background-image:
      radial-gradient(ellipse 70% 50% at 18% 8%, rgba(220, 38, 56, 0.10), transparent 55%),
      radial-gradient(ellipse 80% 50% at 80% 0%, rgba(59, 130, 246, 0.07), transparent 55%),
      radial-gradient(ellipse 60% 40% at 100% 100%, rgba(220, 38, 56, 0.05), transparent 50%);
    background-attachment: fixed;
  }

  /* Subtle grid pattern overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(138, 155, 189, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(138, 155, 189, 0.025) 1px, transparent 1px);
    background-size: 40px 40px;
    z-index: 0;
  }

  .num { font-family: 'Barlow Condensed', sans-serif; font-variant-numeric: tabular-nums; }

  /* ───── Top bar ───── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(6, 14, 28, 0.85);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--border);
  }
  .topbar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  /* ───── Universal crest badge ───── */
  /* Every logo lives inside a .crest-badge &mdash; white circular plate so any logo
     reads cleanly on the dark surface. Size variants below. */
  .crest-badge {
    background: #ffffff;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.6),
      0 6px 16px -4px rgba(0, 0, 0, 0.45);
    position: relative;
    overflow: hidden;
  }
  .crest-badge img {
    width: 82%;
    height: 82%;
    object-fit: contain;
    object-position: center;
  }
  .crest-badge--sm { width: 40px; height: 40px; }
  .crest-badge--md { width: 56px; height: 56px; }
  .crest-badge--lg { width: 96px; height: 96px; }
  .crest-badge--xs { width: 28px; height: 28px; }

  /* Topbar uses --sm */
  .brand-mark {
    flex-shrink: 0;
  }
  .brand-text { line-height: 1.1; }
  .brand-name {
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.01em;
  }
  .brand-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 1px;
  }
  .topbar-meta {
    display: flex;
    align-items: center;
    gap: 20px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .topbar-meta b {
    color: var(--text);
    font-weight: 600;
  }
  .weather-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text);
    white-space: nowrap;
  }
  .weather-chip .weather-icon { font-size: 15px; line-height: 1; }
  .weather-chip .weather-temp { font-weight: 700; color: var(--text); }
  .weather-chip .weather-label { color: var(--muted); }
  .live-dot {
    display: inline-block;
    width: 6px; height: 6px;
    background: var(--win);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.18);
    margin-right: 6px;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  @media (max-width: 700px) {
    .topbar-meta .meta-hide { display: none; }
  }

  /* ───── News ticker ───── */
  .ticker-wrap {
    background: var(--bg-deep);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    position: relative;
    z-index: 2;
  }
  .ticker-wrap::before, .ticker-wrap::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  .ticker-wrap::before { left: 0;  background: linear-gradient(90deg, var(--bg-deep), transparent); }
  .ticker-wrap::after  { right: 0; background: linear-gradient(-90deg, var(--bg-deep), transparent); }
  .ticker {
    display: flex;
    gap: 36px;
    align-items: center;
    padding: 9px 0;
    white-space: nowrap;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    width: max-content;
    animation: tickerScroll 110s linear infinite;
  }
  .ticker:hover { animation-play-state: paused; }
  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .ticker-item::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--azz-bright);
    box-shadow: 0 0 0 2px rgba(96, 165, 250, 0.18);
    flex-shrink: 0;
  }
  .ticker-item b {
    font-weight: 800;
    color: var(--rosso);
    letter-spacing: 0.18em;
  }
  .ticker-item .breaking {
    color: var(--rosso);
    font-weight: 800;
    letter-spacing: 0.2em;
  }
  @keyframes tickerScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ───── Main ───── */
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 28px 24px 64px;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 600px) {
    main { padding: 20px 16px 56px; }
  }

  /* ───── Section header ───── */
  .section-h {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin: 32px 0 14px;
    padding-bottom: 8px;
  }
  .section-h:first-of-type { margin-top: 0; }
  .section-h h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text);
  }
  .section-h-with-crest .crest-badge {
    margin-right: 4px;
  }
  .section-h .h-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
  }
  .section-h .h-meta {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
  }

  /* ───── Card ───── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    position: relative;
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
  }
  .card-h {
    padding: 14px 18px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .card-h-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .card-h-title::before {
    content: '';
    width: 3px; height: 14px;
    background: var(--azz);
    border-radius: 2px;
  }
  .card-h-meta {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .card-body { padding: 16px 18px; }
  .card-body.tight { padding: 0; }

  /* ───── Hero status bar ───── */
  .hero {
    background: linear-gradient(135deg, var(--surface-raised) 0%, var(--surface) 100%);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px 28px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }
  .hero::after {
    content: '';
    position: absolute;
    top: -50%; right: -10%;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.18), transparent 60%);
    pointer-events: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr 1fr;
    gap: 24px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 1100px) {
    .hero-grid { grid-template-columns: 1fr 1fr 1fr; gap: 18px; }
    .hero-title-block { grid-column: span 3; }
  }
  @media (max-width: 600px) {
    .hero-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
    .hero-title-block { grid-column: span 2; }
  }
  @media (max-width: 480px) {
    .hero { padding: 20px; }
    .hero-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
  }
  .hero-title-flex {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  /* Hero crest uses --lg variant of crest-badge */
  @media (max-width: 600px) {
    .hero-title-flex { gap: 16px; }
    .crest-badge--lg { width: 72px; height: 72px; }
  }
  .hero-eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--azz-bright);
    margin-bottom: 4px;
  }
  .hero-title {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: clamp(28px, 4.5vw, 40px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--paper);
    margin-bottom: 6px;
  }
  .hero-title em { font-style: italic; font-weight: 400; color: var(--azz-bright); }
  .hero-sub {
    font-family: 'Manrope', sans-serif;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .stat-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: clamp(36px, 5vw, 48px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .stat-num.muted { color: var(--muted); }
  .stat-num .frac { font-size: 0.55em; color: var(--muted); margin-left: 2px; }
  .stat-lab {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dim);
    margin-top: 4px;
  }

  /* ───── Venue cards (Home Ground + Team Bar) ───── */
  .venues-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 24px;
  }
  @media (max-width: 700px) { .venues-row { grid-template-columns: 1fr; } }
  .venue-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s ease, transform 0.2s ease;
    position: relative;
    overflow: hidden;
    min-height: 292px;
    display: flex;
    flex-direction: column;
  }
  .venue-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 100% 0%, rgba(59, 130, 246, 0.08), transparent 55%);
    pointer-events: none;
    z-index: 1;
  }
  .venue-card:hover { border-color: var(--border-hi); transform: translateY(-2px); }
  .venue-media {
    height: 128px;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: var(--bg-deep);
  }
  .venue-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95) contrast(1.04) brightness(0.82);
  }
  .venue-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(7,16,30,0.05), rgba(7,16,30,0.78));
    pointer-events: none;
  }
  .venue-content {
    padding: 16px 20px 18px;
    position: relative;
    z-index: 2;
    flex: 1;
  }
  .venue-brand-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .venue-logo-plate {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.65), 0 8px 18px -8px rgba(0,0,0,0.75);
    flex-shrink: 0;
  }
  .venue-logo-plate img {
    max-width: 82%;
    max-height: 82%;
    object-fit: contain;
  }
  .venue-tag {
    display: inline-block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--azz-bright);
    background: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(59, 130, 246, 0.3);
    padding: 4px 10px;
    border-radius: 3px;
    margin-bottom: 0;
    position: relative;
    z-index: 1;
  }
  .venue-tag-bar {
    color: var(--draw);
    background: rgba(234, 179, 8, 0.12);
    border-color: rgba(234, 179, 8, 0.3);
  }
  .venue-name {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 22px;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--paper);
    margin-bottom: 6px;
    position: relative;
    z-index: 1;
  }

  .venue-name a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(96, 165, 250, 0.35);
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .venue-name a:hover {
    color: var(--azz-bright);
    border-color: var(--azz-bright);
  }

  .venue-addr {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
  }
  .venue-note {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--dim);
    line-height: 1.5;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }

  /* ───── Competitions: minimalist strip ───── */
  .comps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 24px;
  }
  @media (max-width: 900px) { .comps { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .comps { grid-template-columns: 1fr; } }

  .comp-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .comp-card:hover {
    border-color: var(--border-hi);
    transform: translateY(-2px);
  }
  .comp-text { min-width: 0; flex: 1; }
  .comp-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .comp-meta {
    font-family: 'Manrope', sans-serif;
    font-size: 12px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
    line-height: 1.2;
  }
  .comp-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .comp-dot.active { background: var(--win); box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.18); }
  .comp-dot.pending { background: var(--draw); }
  .comp-dot.locked { background: var(--dim); }


  /* ───── Competition dashboard cleanup ───── */
  .comp-card-fm {
    position: relative;
    overflow: hidden;
    align-items: stretch;
    gap: 16px;
    padding: 18px 18px 16px;
    min-height: 142px;
    background:
      linear-gradient(135deg, rgba(36, 50, 86, 0.96), rgba(10, 18, 34, 0.98) 58%, rgba(8, 13, 25, 0.98)),
      var(--surface);
    border-color: rgba(71, 86, 133, 0.72);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.045), 0 18px 40px -28px rgba(0,0,0,.9);
  }
  .comp-card-fm::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--azz-bright);
    opacity: .82;
  }
  .comp-card-fm::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(255,255,255,.045), transparent 38%),
      radial-gradient(circle at 18% 18%, rgba(96,165,250,.15), transparent 34%);
  }
  .comp-card-fm:hover { border-color: rgba(96,165,250,.72); transform: translateY(-2px); }
  .comp-card--cup::before { background: var(--draw); }
  .comp-card--ont::before { background: var(--rosso); }
  .comp-card--nat::before { background: linear-gradient(180deg, #c8102e, #60a5fa); }
  .comp-card--cup::after { background: radial-gradient(circle at 18% 18%, rgba(234,179,8,.16), transparent 34%); }
  .comp-card--ont::after { background: radial-gradient(circle at 18% 18%, rgba(220,38,56,.16), transparent 34%); }
  .comp-card--nat::after { background: radial-gradient(circle at 18% 18%, rgba(220,38,56,.14), transparent 32%), radial-gradient(circle at 92% 4%, rgba(96,165,250,.12), transparent 28%); }
  .comp-card-fm .crest-badge {
    align-self: center;
    width: 70px;
    height: 70px;
    flex: 0 0 70px;
    z-index: 1;
  }
  .comp-main {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 9px;
    position: relative;
    z-index: 1;
  }
  .comp-topline {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }
  .comp-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 15px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #f8fbff;
    line-height: 1.05;
    text-shadow: 0 1px 10px rgba(0,0,0,.45);
  }
  .comp-phase {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #bfdbfe;
    border: 1px solid rgba(96, 165, 250, 0.45);
    background: rgba(59, 130, 246, 0.16);
    padding: 4px 8px;
    border-radius: 4px;
    white-space: nowrap;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.05);
  }
  .comp-phase.gold {
    color: #fde68a;
    border-color: rgba(234, 179, 8, 0.48);
    background: rgba(234, 179, 8, 0.14);
  }
  .comp-phase.locked {
    color: #cbd5e1;
    border-color: rgba(148, 163, 184, 0.35);
    background: rgba(148, 163, 184, 0.10);
  }
  .comp-line {
    font-size: 12px;
    color: #b7c3db;
    line-height: 1.35;
  }
  .comp-line b {
    color: #ffffff;
    font-weight: 850;
  }
  .comp-stage {
